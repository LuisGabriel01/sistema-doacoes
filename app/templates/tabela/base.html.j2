<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link href="https://unpkg.com/gridjs/dist/theme/mermaid.min.css" rel="stylesheet" />
    <script src="https://unpkg.com/gridjs/dist/gridjs.umd.js"></script>
</head>
<body>
    <a href="{{ url_for('home.home')}}"><h2>Voltar à Tela Inicial</h2></a>
    {% block botao_adicionar %}{% endblock %}
    <div id="table"></div>
    <script>
        new gridjs.Grid({
        columns: [
                {
                    id: '{{ columns[0] }}',
                    name: '{{ columns[0] | capitalize }}',
                    formatter: (cell) => gridjs.html(`<a href="${cell.url}">${cell.name}</a>`)
                },
                {% for column_name in columns[1:] %}
                    {
                        id: '{{ column_name }}',
                        name: '{{ column_name | capitalize }}',
                    },
                {% endfor %}
        ],
        data: [
            {% for row in query %}
                {
                    {{ columns[0] }}: {
                        name: "{{ row|attr(columns[0]) }}",
                        {% if table in (doacao, assistido) %}
                            url: "{{ url_for('registro.ficha', table=table, id=row.id)}}",
                            },
                        {% else %}
                            url: "{{ url_for('doacao.ficha', table=table, id=row.id)}}",
                            },
                        {% endif %}
                    {% for column_name in columns[1:] %}
                        {{ column_name }}: "{{ row|attr(column_name) }}",
                    {% endfor %}
                },
            {% endfor %}
        ],
        search: true,
        sort: true,
        pagination: true,
        }).render(document.getElementById('table'))

    </script>
    <!-- {% set columns = ['nome', 'email', 'telefone', 'atividade_remunerada', 'renda', 'criancas_pequenas'] %}
    <table border="1">

        <tr>
            {% for column_name in columns %}
                <th>{{ column_name | capitalize }}</th>
            {% endfor %}
        </tr>

        {% for row in query %}
            <tr> 
                {% for column_name in columns %}
                    <td>{{ row|attr(column_name) }}</td> 
                {% endfor %}
            </tr> 
        {% endfor %}
    </table> -->
</body>
</html>