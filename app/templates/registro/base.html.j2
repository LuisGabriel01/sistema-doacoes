<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>Test</title>
    <style>
        nav a {
            color: #d64161;
            font-size: 3em;
            margin-left: 50px;
            text-decoration: none;
        }
    </style>
</head>
<body>
    <hr>
    <div class="content">
    <form method="POST" action="{{ url_for(request.endpoint, **request.view_args) }}">
        {{ form.csrf_token }}
        {% for field in fields %}
        <p>
            {{ form[field.name].label }}
            {{ form[field.name](size=field.size, step=field.step, disabled=disabled) }}
            {% if form.nome.errors %}
                {% for error in form.nome.errors %}
                    <span class="error">{{ error }}</span>
                {% endfor %}
            {% endif %}
        </p>
        {% endfor %}
        <input type="submit" value="Salvar">
    </form>
    </div>
</body>
</html>