{% extends 'cadastro/formulario/base.html.j2' %}
{% set title = 'Ficha de Doador' %}
{% set table = 'doador' %}

{% block botao_ver_entregas %}
    <input type="button" value="Ver coletas" onclick="location.href='{{ url_for('doacao.tabela_doacao', table='coleta', doador=request.view_args['id']) }}'">
{% endblock %}

{% block botao_nova_doacao %}
    <input type="button" value="Fazer Nova Coleta" onclick="location.href='{{ url_for('doacao.tabela_itens', id=0, table='coleta', doador=request.view_args['id']) }}'">
{% endblock %}

{% set fields = [
        {
            'name': 'nome',
            'size': 50,
        },
        {
            'name': 'endereco',
            'size': 100,
        },
        {
            'name': 'email',
            'size': 50,
        },
        {
            'name': 'telefone',
            'size': 20,
        },
    ]
%}