{% extends 'cadastro/ficha/base.html.j2' %}
{% set title = 'Ficha de Assistido' %}
{% set table = 'assistido' %}

{% block botao_ver_doacoes %}
    <input type="button" value="Ver Entregas" onclick="location.href='{{ url_for('doacao.tabela_doacao', table='entrega', assistido=request.view_args['id']) }}'">
{% endblock %}

{% block botao_nova_doacao %}
