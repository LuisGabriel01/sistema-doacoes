{% extends 'doacao/_base.html.j2' %}

{# {% block title %}{{ title }}{% endblock %} #}
{% set title %}{{ table_title }}{% endset %}

{% block content %}
<div id="table"></div>
<script>
    new gridjs.Grid({
    columns: [
            {
                id: 'adicionar',
                name: '',
                formatter: (cell) => gridjs.html(`<a href="${cell.url}">${cell.name}</a>`)
            },
            {
                id: '{{ columns[0] }}',
                name: '{{ columns[0] | capitalize }}',
                {# formatter: (cell) => gridjs.html(`<a href="${cell.url}">${cell.name}</a>`) #}
            },
            {% for column_name in columns[1:] %}
                {
                    id: '{{ column_name }}',
                    name: '{{ column_name | capitalize }}',
                },
            {% endfor %}
    ],
    data: [
        {% for row in query %}
            {
                adicionar: {
                    name: 'Adicionar este item',
                    url: "{{ url_for('doacao.tabela_adicionar_item', table=request.view_args['table'], id=request.view_args['id'], nome_item_id=row.id)}}",
                },
                {{ columns[0] }}: "{{ row|attr(columns[0]) }}",
                {% for column_name in columns[1:] %}
                    {{ column_name }}: "{{ row|attr(column_name) }}",
                {% endfor %}
            },
        {% endfor %}
    ],
    search: true,
    sort: true,
    pagination: true,
    }).render(document.getElementById('table'))
</script>
{% endblock %}