{% extends 'base.html.j2' %}

{% set title %}Doação: {{ table_title }}{% endset %}

{% block content %}


{% if request.view_args.get('id') %}
    <a href="{{ request.path.rstrip('/').split('/')[:-1] | join('/') or '/' }}" class="btn btn-secondary">
        Voltar
    </a>
    <input type="button" value="Adicionar Item" onclick="location.href='{{ url_for('doacao.tabela_escolher_item', **request.view_args) }}'">
    <input type="button" value="Remover Doação" onclick="location.href='{{ url_for('doacao.tabela_deletar', **request.view_args) }}'">
{% endif %}

<div id="table"></div>

<script>

    new gridjs.Grid({
    columns: [
            {
                id: '{{ columns[0] }}',
                name: '{{ columns[0] | capitalize }}',
                formatter: (cell) => gridjs.html(`<a href="${cell.url}">${cell.name}</a>`)
            },
            {% for column_name in columns[1:] %}
                {
                    id: '{{ column_name }}',
                    name: '{{ column_name | capitalize }}',
                },
            {% endfor %}
            
            {% if request.view_args.get('id') %}
                {
                    id: 'excluir',
                    name: 'Excluir item',
                    formatter: (cell) => gridjs.html(cell) 
                },
            {% endif %} 
            ],
    data: [
        {% for row in query %}
            {
                {{ columns[0] }}: {
                    name: "{{ row|attr(columns[0]) }}",
                    url: "{{ url_for('doacao.tabela_itens', table=table, id=row.id)}}",
                    },
                {% for column_name in columns[1:] %}
                    {{ column_name }}: "{{ row|attr(column_name) }}",
                {% endfor %}
                
                {% if request.view_args.get('id') %}
                    excluir: `
                        <button onclick="location.href='{{ url_for('doacao.item_deletar', table=request.view_args.get('table'), id=row.id) }}'"
                                style="color: red; border: none; background: none; font-size: 20px; cursor: pointer; padding: 0;"
                                title="Remover este item">
                            &times;
                        </button>
                    `
                {% endif %}
            },
        {% endfor %}
    ],
    search: true,
    sort: true,
    pagination: true,
    }).render(document.getElementById('table'))
</script>
{% endblock %}